rules_version = '2';

// ─────────────────────────────────────────────────────────────────────────────
// Firestore Security Rules — X PPLG 2 Web App
//
// Prinsip Keamanan:
//   1. Public read untuk data konten (students, projects, achievements,
//      cinematography, schedule) → Pengunjung tanpa akun bisa melihat semua
//      data publik.
//   2. Siswa hanya bisa update PROFIL MILIKNYA SENDIRI
//      → Divalidasi via isStudentOwner() yang mengecek field userId di dokumen.
//   3. Admin bisa melakukan semua operasi (create, read, update, delete)
//      → Divalidasi via isAdmin() yang membaca role dari koleksi users.
//   4. Pending items:
//      - Siswa AUTHENTICATED bisa CREATE dan READ dokumen MILIKNYA SENDIRI
//        (where studentId == uid). Ini kunci utama agar pending submission
//        bisa tampil di halaman publik tanpa membuka akses ke semua pending.
//      - Admin bisa READ SEMUA dan DELETE (approve/reject).
//
// Deploy rules ini via:
//   firebase deploy --only firestore:rules
// ─────────────────────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users Collection ───────────────────────────────────────────────────
    // Dokumen user berisi: { role, name, email, studentId? }
    // Hanya pemilik dan admin yang bisa membaca data user
    match /users/{uid} {
      allow read:   if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow create: if isAdmin();
      allow update: if isAdmin() || request.auth.uid == uid;
      allow delete: if isAdmin();
    }

    // ── Students Collection ────────────────────────────────────────────────
    // Public read → semua pengunjung bisa melihat direktori siswa
    // Update → hanya pemilik profil (self-edit) atau admin
    // Create/Delete → hanya admin
    match /students/{studentId} {
      allow read:   if true;
      allow create: if isAdmin();
      allow update: if isAdmin() || isStudentOwner(studentId);
      allow delete: if isAdmin();
    }

    // ── Projects Collection ────────────────────────────────────────────────
    // Public read. Siswa terautentikasi bisa create (melalui alur pending).
    // Update & Delete → pemilik konten (userId) atau admin.
    match /projects/{projectId} {
      allow read:   if true;
      allow create: if request.auth != null; // Admin approve via batch dari pendingItems
      allow update: if isAdmin() || request.auth.uid == resource.data.userId;
      allow delete: if isAdmin() || request.auth.uid == resource.data.userId;
    }

    // ── Achievements Collection ────────────────────────────────────────────
    // Public read. Siswa terautentikasi bisa create (melalui alur pending).
    // Update & Delete → pemilik konten (userId) atau admin.
    match /achievements/{achievementId} {
      allow read:   if true;
      allow create: if request.auth != null;
      allow update: if isAdmin() || request.auth.uid == resource.data.userId;
      allow delete: if isAdmin() || request.auth.uid == resource.data.userId;
    }

    // ── Cinematography Collection ──────────────────────────────────────────
    // Public read. Siswa terautentikasi bisa create (melalui alur pending).
    // Update & Delete → pemilik konten (userId) atau admin.
    match /cinematography/{itemId} {
      allow read:   if true;
      allow create: if request.auth != null;
      allow update: if isAdmin() || request.auth.uid == resource.data.userId;
      allow delete: if isAdmin() || request.auth.uid == resource.data.userId;
    }

    // ── Schedule Collection ────────────────────────────────────────────────
    // [FIXED] Koleksi ini sebelumnya tidak ada di rules sehingga listener
    // subscribeToSchedule() selalu melempar permission-denied.
    // Public read → semua orang bisa melihat jadwal kelas.
    // Write → hanya admin yang bisa mengubah jadwal.
    match /schedule/{dayId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ── Pending Items Collection ───────────────────────────────────────────
    // [FIXED] Aturan baru: siswa yang login bisa READ dokumen MILIK MEREKA
    // sendiri (studentId == uid). Ini memungkinkan halaman Projects,
    // Achievements, dan Cinematography menampilkan status pending submission
    // tanpa membuka akses ke seluruh koleksi pendingItems.
    // Admin tetap bisa melihat dan menghapus SEMUA dokumen pending.
    match /pendingItems/{pendingId} {
      allow create: if request.auth != null;
      allow read:   if isAdmin() ||
                      (request.auth != null &&
                       resource.data.studentId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // ── Helper Functions ───────────────────────────────────────────────────

    /**
     * Cek apakah user yang sedang login adalah admin.
     * Membaca field role dari dokumen users/{uid}.
     */
    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    /**
     * Cek apakah user yang sedang login adalah pemilik profil siswa.
     * Membandingkan Firebase UID dengan field userId di dokumen students.
     *
     * Ini adalah implementasi aturan Self-Edit:
     * "Siswa tidak boleh dan tidak bisa mengedit data milik siswa lain."
     * (BRD — Core Business Rules, Pasal Otorisasi Ketat)
     */
    function isStudentOwner(studentId) {
      return request.auth != null &&
        get(/databases/$(database)/documents/students/$(studentId)).data.userId == request.auth.uid;
    }
  }
}
